{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Negative Case Generator Input",
  "type": "object",
  "required": [
    "taskKey",
    "inputContext"
  ],
  "additionalProperties": false,
  "properties": {
    "taskKey": {
      "const": "negative-case-generator"
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "inputContext": {
      "type": "object",
      "additionalProperties": true
    },
    "governanceContext": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    }
  }
}
