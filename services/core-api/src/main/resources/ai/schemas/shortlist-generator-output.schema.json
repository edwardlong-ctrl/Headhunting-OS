{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Shortlist Generator Output",
  "type": "object",
  "required": [
    "taskKey",
    "summary",
    "outputs",
    "requiresHumanReview"
  ],
  "additionalProperties": false,
  "properties": {
    "taskKey": {
      "const": "shortlist-generator"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "outputs": {
      "type": "object",
      "additionalProperties": true
    },
    "riskSignals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "requiresHumanReview": {
      "type": "boolean"
    }
  }
}
