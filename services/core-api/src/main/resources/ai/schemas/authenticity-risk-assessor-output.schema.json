{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.recruitingtransactionos.dev/ai/authenticity-risk-assessor-output.schema.json",
  "type": "object",
  "properties": {
    "authenticityRisk": {"type": "string", "enum": ["low", "medium", "high"]},
    "specificityScore": {"type": "integer", "minimum": 0, "maximum": 100},
    "independentEvidenceGap": {"type": "boolean"},
    "flags": {"type": "array", "items": {"type": "string", "minLength": 1}}
  },
  "required": ["authenticityRisk", "specificityScore", "independentEvidenceGap", "flags"],
  "additionalProperties": false
}
