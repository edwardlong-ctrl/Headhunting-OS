SPRING_PROFILES_ACTIVE=staging
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/recruiting_os
SPRING_DATASOURCE_USERNAME=rto_app
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
CORE_API_FLYWAY_ENABLED=true

RTO_AUTH_JWT_ISSUER=recruiting-transaction-os
RTO_AUTH_JWT_SECRET=CHANGE_ME_32_BYTE_MINIMUM_JWT_SECRET

RTO_DOCUMENT_STORAGE_ROOT_DIR=/var/lib/rto/documents
RTO_DOCUMENT_STORAGE_VIRUS_SCAN_MODE=noop

RTO_AI_DEEPSEEK_API_KEY=CHANGE_ME_DEEPSEEK_KEY
RTO_AI_ROUTE_CANDIDATE_PROFILE_MODEL=deepseek-v4-pro
RTO_AI_ROUTE_AUTHENTICITY_MODEL=deepseek-v4-pro
RTO_AI_ROUTE_INTERVIEW_FEEDBACK_MODEL=deepseek-v4-pro

RTO_PUBLIC_BASE_URL=https://api.staging.example.invalid
RTO_FRONTEND_ORIGIN=https://app.staging.example.invalid
RTO_DEPLOYMENT_DATABASE_MANAGED=false

RTO_OBJECT_STORAGE_PROVIDER=local-filesystem
RTO_OBJECT_STORAGE_BUCKET=rto-documents
RTO_OBJECT_STORAGE_ENDPOINT=https://object-storage.staging.example.invalid
RTO_OBJECT_STORAGE_LOCAL_ROOT_DIR=/var/lib/rto/documents

MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
CORE_API_PORT=8080
WEB_PORT=8088
