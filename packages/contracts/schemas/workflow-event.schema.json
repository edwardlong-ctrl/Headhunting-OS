{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recruiting-transaction-os.local/contracts/workflow-event.schema.json",
  "title": "WorkflowEvent",
  "type": "object",
  "$comment": "WorkflowEvent is required for key state transitions. Records are append-only; corrections are new events.",
  "properties": {
    "workflow_event_id": { "type": "string", "format": "uuid" },
    "organization_id": { "type": "string", "format": "uuid" },
    "entity_namespace": { "type": "string", "enum": ["identity", "recruiting", "governance", "workflow", "audit"] },
    "entity_type": { "type": "string", "minLength": 1 },
    "entity_id": { "type": "string", "format": "uuid" },
    "entity_version": { "type": "integer", "minimum": 1 },
    "action": { "type": "string", "minLength": 1 },
    "before_state": { "type": "object" },
    "after_state": { "type": "object" },
    "actor_user_id": { "type": "string", "format": "uuid" },
    "actor_role": { "$ref": "truth-layer.enums.schema.json#/$defs/actor_role" },
    "source_type": { "type": "string", "minLength": 1 },
    "source_ref_id": { "type": "string", "format": "uuid" },
    "ai_task_run_id": { "type": "string", "format": "uuid" },
    "review_event_id": { "type": "string", "format": "uuid" },
    "reason": { "type": "string", "minLength": 1 },
    "idempotency_key": { "type": "string" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "previous_event_id": { "type": "string", "format": "uuid" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "workflow_event_id",
    "organization_id",
    "entity_namespace",
    "entity_type",
    "entity_id",
    "action",
    "before_state",
    "after_state",
    "actor_user_id",
    "actor_role",
    "source_type",
    "reason",
    "occurred_at",
    "created_at"
  ],
  "additionalProperties": true
}
