{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recruiting-transaction-os.local/contracts/ai-task-run.schema.json",
  "title": "AITaskRun",
  "type": "object",
  "$comment": "AITaskRun records AI-assisted actions and keeps model/provider observability out of canonical truth.",
  "properties": {
    "ai_task_run_id": { "type": "string", "format": "uuid" },
    "organization_id": { "type": "string", "format": "uuid" },
    "ai_task_definition_id": { "type": "string", "format": "uuid" },
    "task_version": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["created", "running", "succeeded", "failed", "cancelled"]
    },
    "input_schema_version": { "type": "string", "minLength": 1 },
    "output_schema_version": { "type": "string", "minLength": 1 },
    "prompt_version": { "type": "string", "minLength": 1 },
    "model_provider": { "type": "string", "minLength": 1 },
    "model_name": { "type": "string", "minLength": 1 },
    "model_version": { "type": "string" },
    "tool_calls": { "type": "array", "items": { "type": "object" } },
    "source_ref_ids": { "type": "array", "items": { "type": "string", "format": "uuid" } },
    "target_entity_type": { "type": "string" },
    "target_entity_id": { "type": "string", "format": "uuid" },
    "write_back_target": {
      "type": "string",
      "enum": [
        "none",
        "no_write_back",
        "claim_ledger_proposal",
        "review_queue",
        "human_review_required",
        "canonical_candidate_profile",
        "client_safe_projection",
        "job_profile",
        "company_profile",
        "consent_disclosure",
        "workflow_action",
        "commercial_or_placement"
      ],
      "$comment": "Governance metadata only. This field does not execute write-back behavior or canonical writes."
    },
    "human_review_status": {
      "type": "string",
      "enum": [
        "not_required",
        "required",
        "pending",
        "approved",
        "rejected",
        "needs_revision",
        "expired"
      ],
      "$comment": "Governance metadata only. This field records review state and does not execute approval or write-back behavior."
    },
    "input_payload": {
      "type": ["object", "array"],
      "$comment": "Validated execution input payload used for replay. Not canonical fact storage."
    },
    "output_payload": {
      "type": ["object", "array"],
      "$comment": "Validated execution output payload captured for audit and replay. Not canonical fact storage."
    },
    "requested_by_user_id": { "type": "string", "format": "uuid" },
    "requested_by_role": { "type": "string", "enum": ["owner", "consultant", "client", "candidate", "admin", "system", "ai"] },
    "correlation_id": { "type": "string", "format": "uuid" },
    "causation_id": { "type": "string", "format": "uuid" },
    "replayed_from_ai_task_run_id": { "type": "string", "format": "uuid" },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "failure_reason": {
      "type": "string",
      "maxLength": 512,
      "$comment": "Safe single-line failure reason only. Do not store stack traces, provider secrets, prompts, or raw model output."
    },
    "error_code": { "type": "string" },
    "cost_units": { "type": "number", "minimum": 0 },
    "trace_ref": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "version": { "type": "integer", "minimum": 1 }
  },
  "required": [
    "ai_task_run_id",
    "organization_id",
    "ai_task_definition_id",
    "task_version",
    "status",
    "input_schema_version",
    "output_schema_version",
    "prompt_version",
    "model_provider",
    "model_name",
    "human_review_status",
    "started_at",
    "created_at",
    "version"
  ],
  "additionalProperties": true
}
